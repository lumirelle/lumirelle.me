{
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "prepare": "bun run --parallel simple-git-hooks cert",
    "cert": "bun run ./scripts/cert.ts",
    "static": "premove temp && degit lumirelle/static temp --force && bun run ./scripts/copy-sponsors",
    "compress": "bun run ./scripts/img-compress-staged.ts",
    "photos": "bun run ./scripts/photos-manage.ts",
    "dev": "vite --port 3333 --open",
    "redirects": "bun run ./scripts/redirects.ts",
    "build": "bun run static && NODE_ENV=production vite-ssg build && bun run --parallel ./scripts/copy-fonts.ts ./scripts/rss.ts && bun run ./scripts/copy-dist-redirects.ts",
    "start": "vite preview",
    "lint": "bun --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "typecheck": "vue-tsc --build --noEmit",
    "unused": "knip-bun",
    "check": "bun run --parallel lint unused typecheck"
  },
  "workspaces": {
    "catalogs": {
      "dev": {
        "@clack/prompts": "^1.4.0",
        "@octokit/core": "^7.0.6",
        "@octokit/rest": "^22.0.1",
        "d3-hierarchy": "^3.1.2",
        "degit": "^2.8.4",
        "diacritics": "^1.3.0",
        "exifreader": "^4.39.0",
        "feed": "^5.2.1",
        "pathe": "^2.0.3",
        "premove": "^4.0.0",
        "simple-git": "^3.36.0",
        "std-env": "^4.1.0",
        "tinyglobby": "^0.2.16"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/d3-hierarchy": "^3.1.7",
        "@types/diacritics": "^1.3.3",
        "@types/markdown-it-footnote": "^3.0.4",
        "@types/markdown-it-link-attributes": "^3.0.5",
        "@types/node": "^25.9.0",
        "@types/nprogress": "^0.2.3",
        "bun-types": "^1.3.14",
        "typescript": "^6.0.3"
      },
      "build": {
        "@shikijs/markdown-exit": "^4.0.2",
        "@shikijs/transformers": "^4.0.2",
        "@shikijs/twoslash": "^4.0.2",
        "@unocss/preset-web-fonts": "^66.6.8",
        "@vitejs/plugin-vue": "^6.0.7",
        "gray-matter": "^4.0.3",
        "markdown-exit": "^1.0.0-beta.9",
        "markdown-it-anchor": "^9.2.0",
        "markdown-it-footnote": "^4.0.0",
        "markdown-it-github-alerts": "^1.0.1",
        "markdown-it-link-attributes": "^4.0.1",
        "markdown-it-magic-link": "^0.1.4",
        "markdown-it-table-of-contents": "^1.2.0",
        "sharp": "^0.34.5",
        "unocss": "^66.6.8",
        "unplugin-auto-import": "^21.0.0",
        "unplugin-icons": "^23.0.1",
        "unplugin-vue-components": "^32.0.0",
        "unplugin-vue-markdown": "^30.0.0",
        "vite": "^8.0.13",
        "vite-plugin-inspect": "^12.0.0-beta.2",
        "vite-plugin-optimize-exclude": "^0.0.1",
        "vite-ssg": "^28.3.0",
        "vite-svg-loader": "^5.1.1"
      },
      "frontend": {
        "@unhead/vue": "^3.1.0",
        "@unocss/reset": "^66.6.8",
        "@vueuse/core": "^14.3.0",
        "dayjs": "^1.11.20",
        "floating-vue": "^5.2.2",
        "nprogress": "^0.2.0",
        "pinia": "^3.0.4",
        "pixi.js": "^8.18.1",
        "shiki": "^4.0.2",
        "shiki-magic-move": "^1.3.0",
        "simplex-noise": "^4.0.3",
        "vue": "^3.5.34",
        "vue-router": "^5.0.7",
        "vue-router-better-scroller": "^0.0.0"
      },
      "icons": {
        "@iconify/json": "^2.2.474"
      },
      "check": {
        "@antfu/eslint-config": "^9.0.0",
        "@lumirelle/oxlint-config": "^0.4.0",
        "@unocss/eslint-plugin": "^66.6.8",
        "eslint": "^10.4.0",
        "eslint-plugin-oxlint": "^1.65.0",
        "nano-staged": "^1.0.2",
        "oxlint": "^1.65.0",
        "oxlint-tsgolint": "^0.23.0",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657",
        "vue-tsc": "^3.3.0"
      }
    }
  },
  "dependencies": {
    "@iconify/json": "catalog:icons",
    "@unhead/vue": "catalog:frontend",
    "@unocss/reset": "catalog:frontend",
    "@vueuse/core": "catalog:frontend",
    "dayjs": "catalog:frontend",
    "floating-vue": "catalog:frontend",
    "nprogress": "catalog:frontend",
    "pinia": "catalog:frontend",
    "pixi.js": "catalog:frontend",
    "shiki": "catalog:frontend",
    "shiki-magic-move": "catalog:frontend",
    "simplex-noise": "catalog:frontend",
    "vue": "catalog:frontend",
    "vue-router": "catalog:frontend",
    "vue-router-better-scroller": "catalog:frontend"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@clack/prompts": "catalog:dev",
    "@lumirelle/oxlint-config": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@octokit/core": "catalog:dev",
    "@octokit/rest": "catalog:dev",
    "@shikijs/markdown-exit": "catalog:build",
    "@shikijs/transformers": "catalog:build",
    "@shikijs/twoslash": "catalog:build",
    "@types/d3-hierarchy": "catalog:types",
    "@types/diacritics": "catalog:types",
    "@types/markdown-it-footnote": "catalog:types",
    "@types/markdown-it-link-attributes": "catalog:types",
    "@types/node": "catalog:types",
    "@types/nprogress": "catalog:types",
    "@unocss/eslint-plugin": "catalog:check",
    "@unocss/preset-web-fonts": "catalog:build",
    "@vitejs/plugin-vue": "catalog:build",
    "bun-types": "catalog:types",
    "d3-hierarchy": "catalog:dev",
    "degit": "catalog:dev",
    "diacritics": "catalog:dev",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "exifreader": "catalog:dev",
    "feed": "catalog:dev",
    "gray-matter": "catalog:build",
    "knip": "^6.14.1",
    "markdown-exit": "catalog:build",
    "markdown-it-anchor": "catalog:build",
    "markdown-it-footnote": "catalog:build",
    "markdown-it-github-alerts": "catalog:build",
    "markdown-it-link-attributes": "catalog:build",
    "markdown-it-magic-link": "catalog:build",
    "markdown-it-table-of-contents": "catalog:build",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "pathe": "catalog:dev",
    "premove": "catalog:dev",
    "sharp": "catalog:build",
    "simple-git": "catalog:dev",
    "simple-git-hooks": "catalog:check",
    "std-env": "catalog:dev",
    "tinyglobby": "catalog:dev",
    "typescript": "catalog:types",
    "unocss": "catalog:build",
    "unplugin-auto-import": "catalog:build",
    "unplugin-icons": "catalog:build",
    "unplugin-vue-components": "catalog:build",
    "unplugin-vue-markdown": "catalog:build",
    "vite": "catalog:build",
    "vite-plugin-inspect": "catalog:build",
    "vite-plugin-optimize-exclude": "catalog:build",
    "vite-ssg": "catalog:build",
    "vite-svg-loader": "catalog:build",
    "vue-tsc": "catalog:check"
  },
  "overrides": {
    "@types/markdown-it": "npm:markdown-exit@1.0.0-beta.9",
    "markdown-it": "npm:markdown-exit@1.0.0-beta.9",
    "vite": "catalog:build",
    "vue-router": "catalog:frontend"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
